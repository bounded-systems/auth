{
  "name": "@bounded-systems/auth",
  "version": "0.2.0",
  "description": "Service-credential resolver (GitHub, Notion) through a single sanctioned access point",
  "bounded": {
    "tagline": "Service-credential resolver (GitHub, Notion) through a single sanctioned access point",
    "kind": "door",
    "facet": "verb",
    "role": "capability",
    "domain": "auth"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/auth.git"
  },
  "homepage": "https://github.com/bounded-systems/auth#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/auth/issues"
  },
  "keywords": [
    "auth",
    "credentials",
    "github",
    "notion",
    "capability"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bounded-systems/env": "npm:@jsr/bounded-systems__env"
  }
}
